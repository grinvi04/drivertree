# PostgreSQL 연결 문자열 (docker-compose의 기본값 사용 시 그대로 사용 가능)
DATABASE_URL="postgresql://drivetree_user:drivetree_password123!@localhost:5432/drivetree?schema=public"

# JWT 서명용 비밀키 — 반드시 강한 랜덤값으로 설정 (미설정 시 서버 기동 불가)
# 생성 예: openssl rand -hex 64
JWT_SECRET="<strong-random-secret-here>"

# Refresh Token 서명용 비밀키 — JWT_SECRET과 반드시 다른 값 사용 (미설정 시 서버 기동 불가)
JWT_REFRESH_SECRET="<another-strong-random-secret-here>"

# NestJS 서버 포트 (기본 4000, Railway는 자동 주입)
PORT=4000

# CORS 허용 도메인 (콤마 구분). 미설정 시 localhost:3000/3001 + *.vercel.app 자동 허용
# 운영: "https://drivetree.vercel.app"
ALLOWED_ORIGINS=""

# 관리자 계정 시드 — 운영 배포 시 반드시 강한 비밀번호로 변경
# 변경 후 재배포 시 기존 admin 계정 비밀번호가 자동 동기화됨
# 미설정 시 로컬 개발용 기본값(admin / drivetreeadmin123!) 사용
ADMIN_USERNAME="admin"
ADMIN_PASSWORD=""

# NestJS 로그 레벨 (콤마 구분). 운영: "log,warn,error" / 디버그: "log,warn,error,debug,verbose"
NEST_LOG_LEVEL="log,warn,error"

# (선택) Sentry DSN — 설정 시 AllExceptionsFilter에서 5xx 에러를 Sentry로 전송
# https://sentry.io 에서 Node.js 프로젝트 생성 후 DSN 발급
SENTRY_DSN=""

